generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  role                Role                 @default(CUSTOMER)
  verified            Boolean              @default(false)
  phoneNumber         String?
  profileImage        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  employmentStatus    String?
  gender              String?
  kids                String?
  marriageStatus      String?
  verificationPhoto   String?
  applications        Application[]        @relation("CustomerApplications")
  managedApplications Application[]        @relation("ManagerApplications")
  receivedMessages    Chat[]               @relation("ReceivedMessages")
  sentMessages        Chat[]               @relation("SentMessages")
  documents           Document[]
  favorites           Favorite[]
  leasesAsCustomer    Lease[]              @relation("CustomerLeases")
  leasesAsOwner       Lease[]              @relation("OwnerLeases")
  requests            MaintenanceRequest[]
  listings            Property[]           @relation("ListedBy")
  ownedProperties     Property[]           @relation("PropertyOwner")
  chapaSubaccountId   String?
  payoutBankCode      String?
  payoutAccountNumber String?
  payoutAccountName   String?
  transactionsAsPayer Transaction[]        @relation("PayerTransactions")
  transactionsAsPayee Transaction[]        @relation("PayeeTransactions")
  notifications       Notification[]
  reviews             Review[]
  propertyViews       PropertyView[]
  filterLogs          SearchFilterLog[]
  mapInteractions     MapInteraction[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // MESSAGE, APPLICATION, MAINTENANCE, LEASE
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id                  String               @id @default(cuid())
  title               String
  description         String
  assetType           AssetType
  listingType         ListingType[]
  price               Float
  aiPredictedPrice    Float?
  status              PropertyStatus       @default(AVAILABLE)
  propertyType        String?
  bedrooms            Int?
  bathrooms           Int?
  area                Float?
  amenities           String[]
  brand               String?
  model               String?
  year                Int?
  fuelType            String?
  transmission        String?
  mileage             Int?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ownerId             String
  listedById          String
  locationId          String?
  isVerified          Boolean              @default(false)
  applications        Application[]
  ownershipDocuments  Document[]           @relation("PropertyDocuments")
  favoredBy           Favorite[]
  leases              Lease[]
  transactions        Transaction[]
  maintenanceRequests MaintenanceRequest[]
  listedBy            User                 @relation("ListedBy", fields: [listedById], references: [id])
  location            Location?            @relation(fields: [locationId], references: [id])
  owner               User                 @relation("PropertyOwner", fields: [ownerId], references: [id])
  images              PropertyImage[]
  reviews             Review[]
  views               PropertyView[]
}

model Location {
  id         String     @id @default(cuid())
  subcity    String?
  city       String?
  region     String?
  village    String?
  lat        Float?
  lng        Float?
  properties Property[]
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  isMain     Boolean  @default(false)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Lease {
  id               String      @id @default(cuid())
  leaseType        String
  startDate        DateTime
  endDate          DateTime
  totalPrice       Float
  recurringAmount  Float?
  terms            String
  status           LeaseStatus @default(PENDING)
  ownerAccepted    Boolean     @default(false)
  customerAccepted Boolean     @default(false)
  propertyId       String
  customerId       String
  ownerId          String
  createdAt        DateTime    @default(now())
  customer         User        @relation("CustomerLeases", fields: [customerId], references: [id])
  owner            User        @relation("OwnerLeases", fields: [ownerId], references: [id])
  property         Property    @relation(fields: [propertyId], references: [id])
  transactions     Transaction[]
}

model Chat {
  id         String   @id @default(cuid())
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  senderId   String
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
}

model Application {
  id         String   @id @default(cuid())
  status     String   @default("pending")
  message    String?
  propertyId String
  customerId String
  createdAt  DateTime @default(now())
  managerId  String
  customer   User     @relation("CustomerApplications", fields: [customerId], references: [id])
  manager    User     @relation("ManagerApplications", fields: [managerId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
}

model Transaction {
  id              String            @id @default(cuid())
  amount          Float
  currency        String            @default("ETB")
  status          TransactionStatus @default(PENDING)
  type            TransactionType
  payerId         String
  payeeId         String
  leaseId         String?
  propertyId      String?
  chapaReference  String?           @unique
  payoutRef       String?           @unique
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  payer           User              @relation("PayerTransactions", fields: [payerId], references: [id])
  payee           User              @relation("PayeeTransactions", fields: [payeeId], references: [id])
  lease           Lease?            @relation(fields: [leaseId], references: [id])
  property        Property?         @relation(fields: [propertyId], references: [id])
}

model MaintenanceRequest {
  id          String              @id @default(cuid())
  category    MaintenanceCategory
  description String
  status      String              @default("pending")
  images      String[]
  propertyId  String
  customerId  String
  createdAt   DateTime            @default(now())
  customer    User                @relation(fields: [customerId], references: [id])
  property    Property            @relation(fields: [propertyId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  reviewerId String
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])
  reviewer   User     @relation(fields: [reviewerId], references: [id])
}

model Document {
  id         String    @id @default(cuid())
  type       String
  url        String
  verified   Boolean   @default(false)
  userId     String
  uploadedAt DateTime  @default(now())
  propertyId String?
  property   Property? @relation("PropertyDocuments", fields: [propertyId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

model PropertyView {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  viewedAt   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
}

model SearchFilterLog {
  id        String    @id @default(cuid())
  userId    String
  searchType String   // 'property' or 'vehicle'
  filters   Json
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MapInteraction {
  id        String   @id @default(cuid())
  userId    String
  lat       Float
  lng       Float
  zoom      Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  CUSTOMER
  OWNER
  AGENT
  ADMIN
}

enum AssetType {
  HOME
  CAR
}

enum PropertyStatus {
  AVAILABLE
  BOOKED
  SOLD
  RENTED
  UNAVAILABLE
}

enum ListingType {
  RENT
  LEASE
  BUY
  FOR_SALE
}

enum LeaseStatus {
  PENDING
  ACTIVE
  COMPLETED
  TERMINATED
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  INTERNET
  DAMAGE
  CLEANING
  ENGINE
  BATTERY
  TIRE
  OTHER
}

enum TransactionStatus {
  PENDING
  HELD_BY_ADMIN
  PAYOUT_APPROVED
  COMPLETED
  FAILED
  CANCELLED
}

enum TransactionType {
  RENT
  LEASE_DEPOSIT
  BOOKING_FEE
  FULL_PURCHASE
}
